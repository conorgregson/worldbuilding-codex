generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorldVisibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

enum EntityType {
  CHARACTER
  LOCATION
  FACTION
  SPECIES
  RELIGION
  LANGUAGE
  ARTIFACT
  ORGANIZATION
  CULTURE
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  worlds       World[]

  @@index([email])
}

model World {
  id          String          @id @default(cuid())
  userId      String
  title       String
  genre       String?
  description String?
  visibility  WorldVisibility @default(PRIVATE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entities      Entity[]
  relationships Relationship[]
  events        Event[]

  @@index([userId])
  @@index([title])
  @@index([visibility])
}

model Entity {
  id          String     @id @default(cuid())
  worldId     String
  type        EntityType
  name        String
  summary     String?
  description String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  world                 World      @relation(fields: [worldId], references: [id], onDelete: Cascade)
  tags                  EntityTag[]
  outgoingRelationships Relationship[] @relation("SourceEntity")
  incomingRelationships Relationship[] @relation("TargetEntity")
  eventParticipants     EventParticipant[]

  @@index([worldId])
  @@index([worldId, type])
  @@index([worldId, name])
  @@index([type])
}

model EntityTag {
  id        String   @id @default(cuid())
  entityId  String
  tag       String
  createdAt DateTime @default(now())

  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([tag])
  @@unique([entityId, tag])
}

model Relationship {
  id               String    @id @default(cuid())
  worldId          String   
  sourceEntityId   String
  targetEntityId   String
  relationshipType String
  note             String?
  createdAt        DateTime  @default(now())

  world          World  @relation(fields: [worldId], references: [id], onDelete: Cascade)
  sourceEntity   Entity @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity   Entity @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@index([sourceEntityId])
  @@index([targetEntityId])
  @@index([worldId, relationshipType])
}

model Event {
  id          String   @id @default(cuid())
  worldId     String   
  title       String
  dateLabel   String?
  sortYear    Int?
  sortIndex   Int?
  summary     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  world        World               @relation(fields: [worldId], references: [id], onDelete: Cascade)
  participants EventParticipant[]

  @@index([worldId])
  @@index([worldId, sortYear])
  @@index([worldId, sortIndex])
  @@index([title])
}

model EventParticipant {
  id         String   @id @default(cuid())
  eventId    String
  entityId   String
  roleLabel  String?
  createdAt  DateTime @default(now())
  
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  entity  Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([entityId])
  @@index([eventId, entityId])
}